@model ToDo.Models.RegisterViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "會員註冊";
}

<h2 style="text-align: center; font-family: 'Arial', sans-serif; font-weight: bold; color: #444;">
    @ViewData["Title"]
</h2>
<form asp-action="Register" method="post" class="max-w-md mx-auto display-6 bg-white shadow-md rounded">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-red-600 mb-4"></div>

    <div class="form-group">
        <label asp-for="Email" class="block text-gray-700 font-medium mb-2"></label>
        <input asp-for="Email" class="block w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-orange-600 " />
        <span asp-validation-for="Email" class="text-red-600 text-sm"></span>
    </div>

    <div class="mb-4">
        <label asp-for="Password" class="block text-gray-700 font-medium mb-2"></label>
        <input asp-for="Password" class="block w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-orange-600l" type="password" />
        <span asp-validation-for="Password" class="text-red-600 text-sm"></span>
    </div>

    <div class="mb-4">
        <label asp-for="ConfirmPassword" class="block text-gray-700 font-medium mb-2"></label>
        <input asp-for="ConfirmPassword" type="password" class="block w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-orange-600" />
        <span asp-validation-for="ConfirmPassword" class="text-red-600 text-sm"></span>
    </div>
    <button type="submit" class="w-full bg-orange-600 text-white py-2 px-4 rounded hover:bg-orange-700 transition duration-200">註冊</button>

</form>
