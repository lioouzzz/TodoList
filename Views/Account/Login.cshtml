@model ToDo.Models.LoginViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "會員登入";
}

<h2 style="text-align: center; font-family: 'Arial', sans-serif; font-weight: bold; color: #444;">
    @ViewData["Title"]
</h2>
<form asp-action="Login" method="post" class="max-w-md mx-auto p-6 bg-white shadow-md rounded">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-red-600 mb-4"></div>

    <div class="mb-4">
        <label asp-for="Email" class="block text-gray-700 font-medium mb-2"></label>
        <input asp-for="Email" class="block w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-orange-600" />
        <span asp-validation-for="Email" class="text-red-600 text-sm"></span>
    </div>

    <div class="mb-4">
        <label asp-for="Password" class="block text-gray-700 font-medium mb-2"></label>
        <input asp-for="Password" class="block w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-orange-600" type="password" />
        <span asp-validation-for="Password" class="text-red-600 text-sm"></span>
    </div>
    <div class="mb-4 flex items-center">
        <input asp-for="RememberMe" type="checkbox" class="mr-2" />
        <label asp-for="RememberMe" class="text-gray-700"></label>
    </div>

    <button type="submit" class=" w-full bg-orange-600 text-white py-2 px-4 rounded hover:bg-orange-700 transition duration-200">登入</button>

</form>